import requests
from datetime import datetime
import yfinance as yf
import time

# localhost w n8n
webhook = 'http://localhost:5678/webhook/company_parameters'

# tickery firm
tickers = ['TSLA',
           'AMAT',
           'BYDDY', 
           '1810.HK', 
           'NVDA', 
           'TSM', 
           'GOOGL', 
           'ABBNY', 
           'TER', 
           '9880.HK', 
           'XPEV',
           'ASML',
           'LRCX',
           'SNPS',
           'CDNS',
           'ANET',
           'MSFT',
           'AMZN',
           'RKLB',
           '300750.SZ',
           '300124.SZ',
           '601012.SS',
           '300274.SZ',
           'HSAI',
           '2498.HK',
           '002747.SZ',
           '0981.HK',
           'AVGO',
           'AAPL',
           'PLTR',
           '005380.KS',
           'AMD',
           'INTC',
           'FTNT',
           'NEE',
           ]

# dla każdego tickera pobierz wartości wybranych parametrów finansowych
for t in tickers:
    ticker = yf.Ticker(t)
    info = ticker.info
    
    company = info.get("longName") or info.get("shortName")
    price = info.get("currentPrice") or info.get("regularMarketPrice") or info.get("previousClose")
    market_cap = info.get("marketCap")
    volume = info.get("volume")
    high_52w = info.get("fiftyTwoWeekHigh")
    low_52w = info.get("fiftyTwoWeekLow")
    fwd_pe = info.get("forwardPE")
    if fwd_pe is not None and fwd_pe <= 0:
        fwd_pe = None
    dividend_yield = info.get('dividendYield')
    shares_out = info.get('sharesOutstanding')
    total_revenue = info.get('totalRevenue')
    net_income = info.get('netIncomeToCommon')

# zaczytanie total_equity oraz total_assets bezposrednio z bialnsu firm:
    total_equity = ticker.balance_sheet.loc['Stockholders Equity'].iloc[0]
    total_assets = ticker.balance_sheet.loc['Total Assets'].iloc[0]

    total_debt = info.get('totalDebt')
    cash = info.get('totalCash')
    revenue_growth = info.get('revenueGrowth')
    eps_growth = info.get('earningsGrowth')
    ebitda = info.get("ebitda")
    quick_ratio = info.get("quickRatio")
    enterprise_value = info.get("enterpriseValue")

# zaczytanie operating_cashflow i capex bezposrednio ze sprawozdania cashflow:
    operating_cashflow = ticker.cashflow.loc["Operating Cash Flow"].iloc[0]
    capex = ticker.cashflow.loc["Capital Expenditure"].iloc[0]
    free_cashflow = ticker.cashflow.loc["Free Cash Flow"].iloc[0]

# jezeli nie ma (!= różne od) operating_cashflow ale jest free_cashflow i capex:
    if operating_cashflow != operating_cashflow and free_cashflow is not None and capex is not None:
        operating_cashflow = free_cashflow - capex

# jezeli nie ma (!= różne od) free_cashflow ale jest operating_cashflow i capex:
    if free_cashflow != free_cashflow and operating_cashflow is not None and capex is not None:
        free_cashflow = operating_cashflow + capex

# wrzucanie wartości parametrów do googlesheets
    payload = {
        "timestamp": datetime.now().isoformat(timespec="seconds"), 
        'ticker': t,
        'company':company,
        'price': price, 
        'market_cap': market_cap, 
        'volume': volume, 
        '52w_high': high_52w, 
        '52w_low': low_52w, 
        'fwd_pe': fwd_pe,
        'dividend_yield': dividend_yield,
        'shares_out': shares_out,
        'total_revenue': total_revenue,
        'net_income': net_income,
        'total_equity': total_equity,
        'total_assets': total_assets,
        'total_debt': total_debt,
        'cash': cash,
        'revenue_growth': revenue_growth,
        'eps_growth': eps_growth,
        'ebitda': ebitda,
        'quick_ratio': quick_ratio,
        'enterprise_value': enterprise_value,
        'operating_cashflow': operating_cashflow,
        'capex': capex,
        'free_cashflow': free_cashflow,
        'currency': info.get('currency'),
        'financial_currency': info.get('financialCurrency'),
        }
    
    resp = requests.post(webhook, json=payload, timeout=20)
    print('\n')
    print(t, resp.status_code)

# sprawdzenie w jakich walutach zaciągane dane finansowe
    print(f"1.currency - {ticker.info.get('currency')}")
    print(f'2.financialccy - {ticker.info.get('financialCurrency')}')
    time.sleep(4)

